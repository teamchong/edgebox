@@ -0,0 +1,63 @@
+// EdgeBox API — Zig IO bridge for workerd
+// Exposes __edgebox_io_sync and __edgebox_io_batch as native workerd APIs.
+// Backed by Zig functions via C ABI (linked at compile time).
+#pragma once
+
+#include <workerd/jsg/jsg.h>
+#include <kj/string.h>
+
+// C ABI functions provided by Zig (linked at compile time)
+extern "C" {
+  // Synchronous IO: takes JSON request, returns JSON response
+  // e.g. {"op":"readFile","path":"/foo/bar.ts"} → {"ok":true,"data":"..."}
+  const char* edgebox_io_sync(const char* request, int request_len, int* response_len);
+
+  // Batch IO: takes JSON array of requests, returns JSON array of responses
+  const char* edgebox_io_batch(const char* request, int request_len, int* response_len);
+
+  // Free response buffer allocated by Zig
+  void edgebox_io_free(const char* ptr, int len);
+}
+
+namespace workerd::api::node {
+
+class EdgeboxModule final: public jsg::Object {
+public:
+  EdgeboxModule() = default;
+
+  // __edgebox_io_sync(jsonRequest) → jsonResponse
+  kj::String ioSync(kj::String request) {
+    int response_len = 0;
+    const char* response = edgebox_io_sync(
+        request.cStr(), request.size(), &response_len);
+    if (response == nullptr || response_len <= 0) {
+      return kj::str("{\"ok\":false,\"error\":\"io_sync_failed\"}");
+    }
+    auto result = kj::str(kj::StringPtr(response, response_len));
+    edgebox_io_free(response, response_len);
+    return result;
+  }
+
+  // __edgebox_io_batch(jsonArrayRequest) → jsonArrayResponse
+  kj::String ioBatch(kj::String request) {
+    int response_len = 0;
+    const char* response = edgebox_io_batch(
+        request.cStr(), request.size(), &response_len);
+    if (response == nullptr || response_len <= 0) {
+      return kj::str("[]");
+    }
+    auto result = kj::str(kj::StringPtr(response, response_len));
+    edgebox_io_free(response, response_len);
+    return result;
+  }
+
+  JSG_RESOURCE_TYPE(EdgeboxModule) {
+    JSG_METHOD(ioSync);
+    JSG_METHOD(ioBatch);
+  }
+};
+
+#define EW_EDGEBOX_ISOLATE_TYPES \
+  api::node::EdgeboxModule
+
+}  // namespace workerd::api::node
