+  kj::String __edgebox_random_bytes(double size) {
+    int n = (int)size;
+    if (n <= 0 || n > 65536) return kj::str("");
+    char buf[65536];
+    edgebox_random_bytes(buf, n);
+    char hex[131073]; // +1 for NUL
+    const char* h = "0123456789abcdef";
+    for (int i = 0; i < n; i++) {
+      hex[i*2] = h[(unsigned char)buf[i] >> 4];
+      hex[i*2+1] = h[(unsigned char)buf[i] & 0xf];
+    }
+    hex[n*2] = '\0';
+    return kj::str(kj::StringPtr(hex, n*2));
